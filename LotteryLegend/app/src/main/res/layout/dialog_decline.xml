<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvDeclineTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Decline Invitation"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeclineMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:lineSpacingExtra="2dp"
            android:text="Declining may remove your chance permanently."
            android:textColor="#374151"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/layoutDeclineActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDecline"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#F3F4F6"
                app:cornerRadius="18dp"
                app:elevation="0dp" />

            <Space
                android:layout_width="14dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmDecline"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Decline"
                android:textAllCaps="false"
                android:textColor="#DC2626"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:rippleColor="#10DC2626"
                app:strokeColor="#DC2626"
                app:strokeWidth="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>