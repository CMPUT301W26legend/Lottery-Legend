<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardEntrant"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="84dp"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <!-- Profile -->
        <ImageView
            android:id="@+id/imageEntrantProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/ic_profile_avatar"
            android:contentDescription="Entrant profile"
            android:padding="8dp" />

        <!-- Right status -->
        <TextView
            android:id="@+id/textEntrantStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/textEntrantName"
            android:text="Waiting"
            android:textColor="#2563EB"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Waiting" />

        <!-- Main content -->
        <LinearLayout
            android:id="@+id/layoutEntrantInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imageEntrantProfile"
            android:layout_toStartOf="@id/textEntrantStatus"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textEntrantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Due"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="John Due" />

            <TextView
                android:id="@+id/textJoinedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Joined: May 10, 2024 at 2:30 PM"
                android:textColor="#6B7280"
                android:textSize="10sp"
                tools:text="Joined: May 10, 2024 at 2:30 PM" />

            <TextView
                android:id="@+id/textPromoteCoOrganizer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:paddingEnd="4dp"
                android:text="Promote to Co-organizer"
                android:textColor="#2563EB"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Promote to Co-organizer" />

        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>