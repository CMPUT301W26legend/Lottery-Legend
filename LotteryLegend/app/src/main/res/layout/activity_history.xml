<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".entrant.HistoryActivity">

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarHistory"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="#2563EB"
        android:elevation="2dp"
        app:title="History"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white" />

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbarHistory"
        android:background="@android:color/white"
        app:tabGravity="fill"
        app:tabIndicatorColor="#3B82F6"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="#3B82F6"
        app:tabTextColor="#9CA3AF">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tabWaiting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tabAccepted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accepted" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tabNotSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not Selected" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tabCancelled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelled" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Divider under tabs -->
    <View
        android:id="@+id/viewTabDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/tabLayoutHistory"
        android:background="#E5E7EB" />

    <!-- Bottom Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar_entrant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

    <!-- RecyclerView Content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/viewTabDivider"
        android:layout_above="@id/navbar"
        android:clipToPadding="false"
        android:paddingTop="18dp"
        android:paddingBottom="8dp"
        tools:listitem="@layout/history_card_content" />

</RelativeLayout>