<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".entrant.NotificationActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarNotification"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:background="#2563EB"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        app:navigationIcon="@drawable/ic_arrow_left"
        app:navigationIconTint="@android:color/white"
        app:title="Notifications"
        app:titleCentered="false"
        app:titleTextColor="@android:color/white" />

    <TextView
        android:id="@+id/tvMarkAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/toolbarNotification"
        android:layout_alignBottom="@id/toolbarNotification"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:text="Mark all"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/layoutUnreadSummary"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@id/toolbarNotification"
        android:background="#DBEAFE"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_notification_dot" />

        <TextView
            android:id="@+id/tvUnreadSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You have 1 unread notifications"
            android:textColor="#2563EB"
            android:textSize="14sp" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutUnreadSummary"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_notification_tab_selected"
                android:gravity="center"
                android:minWidth="40dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="All"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tabUnread"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_notification_tab_unselected"
                android:gravity="center"
                android:minWidth="64dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Unread"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tabRead"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_notification_tab_unselected"
                android:gravity="center"
                android:minWidth="52dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Read"
                android:textColor="#64748B"
                android:textSize="14sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/filterScroll"
        android:layout_above="@id/layout_navbar_entrant"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        tools:listitem="@layout/item_notification" />

    <include
        android:id="@+id/layout_navbar_entrant"
        layout="@layout/layout_navbar_entrant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>