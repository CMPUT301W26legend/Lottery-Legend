<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogCardRunLottery"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="34dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/textRunLotteryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Run Lottery"
            android:textColor="#172033"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textRunLotteryMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:lineSpacingExtra="2dp"
            android:text="This will randomly select participants. This action cannot be undone."
            android:textColor="#4B5563"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textSampleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Number of participants to sample"
            android:textColor="#172033"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutSampleCount"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Leave blank to use maximum allowed"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:boxStrokeColor="#D1D5DB"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="#9CA3AF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSampleCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:minHeight="56dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="#172033"
                android:textColorHint="#9CA3AF"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textSampleHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Maximum allowed: 20"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/layoutRunLotteryButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCancelRunLottery"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#E5E7EB"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

            <Space
                android:layout_width="14dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonConfirmRunLottery"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Run"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#2563EB"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>