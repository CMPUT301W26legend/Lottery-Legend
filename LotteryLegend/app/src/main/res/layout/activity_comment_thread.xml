<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".entrant.CommentThreadActivity">

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCommentThread"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#2563EB"
        app:contentInsetStartWithNavigation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_left"
        app:navigationIconTint="@android:color/white">

        <TextView
            android:id="@+id/textToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:text="Comments"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Scroll content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollCommentThread"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbarCommentThread"
        app:layout_constraintBottom_toTopOf="@id/commentInputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Parent comment fixed header -->
            <include
                android:id="@+id/layoutParentComment"
                layout="@layout/item_parent_comment_header" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />

            <!-- Replies list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewReplies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                tools:listitem="@layout/item_reply_comment" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom input -->
    <LinearLayout
        android:id="@+id/commentInputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#F3F4F6"
            app:cardCornerRadius="21dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <EditText
                android:id="@+id/editTextReply"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="Write a reply..."
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/buttonSendReply"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Send Reply"
            android:scaleType="centerInside"
            android:src="@drawable/ic_comment_send" />
    </LinearLayout>

    <!-- Bottom Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar_entrant"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>