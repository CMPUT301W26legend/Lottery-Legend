<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogCardPromoteCoOrganizer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="34dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/textPromoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Promote to Co-organizer"
            android:textColor="#172033"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textPromoteMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="start"
            android:lineSpacingExtra="2dp"
            android:text="This user will become a co-organizer and will be removed from the waiting list."
            android:textColor="#4B5563"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/layoutPromoteButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCancelPromote"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#E5E7EB"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

            <Space
                android:layout_width="14dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonConfirmPromote"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Confirm"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#3B82F6"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>